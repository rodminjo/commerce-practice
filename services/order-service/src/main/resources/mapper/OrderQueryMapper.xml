<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rodminjo.commerce.order.adapter.out.persistence.mybatis.OrderQueryMapper">

    <resultMap id="orderRowMap" type="com.rodminjo.commerce.order.adapter.out.persistence.mybatis.OrderRow">
        <id property="id" column="id"/>
        <result property="status" column="status"/>
        <result property="totalAmountMinor" column="total_amount_minor"/>
        <result property="currency" column="currency"/>
        <collection property="items"
                    ofType="com.rodminjo.commerce.order.adapter.out.persistence.mybatis.OrderItemRow">
            <result property="productId" column="item_product_id"/>
            <result property="quantity" column="item_quantity"/>
            <result property="unitPriceMinor" column="item_unit_price_minor"/>
        </collection>
    </resultMap>

    <!-- Read model: order header + line items in one join. Tables resolve via the order_svc search_path. -->
    <select id="findOrderById" resultMap="orderRowMap">
        SELECT o.id::text                AS id,
               o.status                  AS status,
               o.total_amount_minor      AS total_amount_minor,
               o.currency                AS currency,
               i.product_id             AS item_product_id,
               i.quantity               AS item_quantity,
               i.unit_price_minor       AS item_unit_price_minor
        FROM orders o
        LEFT JOIN order_items i ON i.order_id = o.id
        WHERE o.id = #{id}::uuid
        ORDER BY i.id
    </select>
</mapper>
